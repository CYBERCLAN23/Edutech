# 🔒 EduCam AI Server Configuration
# NE JAMAIS COMMITTER CE FICHIER

# Server
PORT=3000
NODE_ENV=development

# Supabase (Database & Auth)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# JWT (Signing tokens)
JWT_SECRET=your-jwt-secret-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# OpenRouter (AI API)
OPENROUTER_API_KEY=sk-or-v1-your-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o

# Notion API (Content Management - Optionnel)
NOTION_API_KEY=
NOTION_LESSONS_DATABASE_ID=
NOTION_VIDEOS_DATABASE_ID=

# Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# Security
CORS_ORIGINS=https://edutech-production-4e49.up.railway.app,https://your-vercel-app.vercel.app
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=10
